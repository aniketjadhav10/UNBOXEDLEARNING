{
  "functions": {
    "api/**/*.ts": {
      "runtime": "@vercel/node@3.2.20"
    }
  },
  "crons": [
    {
      "path": "/api/cron/daily-agenda",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/evening-report",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/cron/weekly-planner",
      "schedule": "0 7 * * 1"
    }
  ]
}
